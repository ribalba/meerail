# Copy to .env and adjust. Sensible localhost defaults apply.

# --- Server ---
# PostgreSQL. docker-compose sets this automatically for the bundled db service.
# For a native run, point it at your Postgres instance:
DATABASE_URL=postgresql+psycopg2://meerail:meerail@localhost:5432/meerail

# Credentials for the bundled Postgres container (docker-compose).
POSTGRES_USER=meerail
POSTGRES_PASSWORD=meerail
POSTGRES_DB=meerail

# Secret used to encrypt any server-side stored credentials and sign tokens.
# CHANGE THIS in production. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-secret-change-me

# Where raw .eml files and attachments are written (a persistent volume in Docker).
DATA_DIR=/data

# Apache Tika endpoint (attachment text extraction). The bundled tika service.
TIKA_URL=http://tika:9998

# Shared secret the agent presents on /api/agent/*. Leave empty to disable the
# check (fine for localhost). Generate a real value for remote deployments.
AGENT_TOKEN=

# Optional shared secret required to use the web UI / REST API. Leave empty for
# an open localhost app; set it (plus TLS) when deploying to a remote server.
SERVER_AUTH_TOKEN=

# Default search time-window in years (0 = search everything). The UI can override.
DEFAULT_SEARCH_YEARS=0

# How many years back to scan addresses for compose autocomplete (0 = all time).
CONTACTS_SCAN_YEARS=1
