# Copy to .env and adjust. Sensible localhost defaults apply.

# --- Server ---
# PostgreSQL. docker-compose sets this automatically for the bundled db service
# (db:5432 on the internal network — the containers do not read this line).
# For a native run, point it at your Postgres instance; reaching the bundled one
# over localhost needs docker-compose.hostports.yml, which publishes the port:
DATABASE_URL=postgresql+psycopg://meerail:meerail@localhost:5432/meerail

# Credentials for the bundled Postgres container (docker-compose).
POSTGRES_USER=meerail
POSTGRES_PASSWORD=meerail
POSTGRES_DB=meerail

# Secret used to encrypt any server-side stored credentials and sign tokens.
# CHANGE THIS in production. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-secret-change-me

# Scratch space for outgoing attachment staging (mail bytes live in Postgres).
# Host-relative by default; docker-compose overrides it to /data in the container.
DATA_DIR=./data

# Apache Tika endpoint, used by the agent for attachment text extraction.
# This loopback address is what docker-compose.hostports.yml publishes, for an
# agent running outside Docker. Inside the compose network Tika is tika:9998.
TIKA_URL=http://127.0.0.1:9998

# Keep each message's original RFC822 bytes in the database (messages.raw_mime).
# Nothing reads them yet — they are kept for future features — and they are
# roughly half the database's size, so set false to ingest without them. Read by
# whichever process ingests mail: the containerised agent picks it up from here
# via docker-compose.agent.yml, a native agent uses store_raw_mime in
# agent/config.toml instead (and that file wins if it sets the key).
STORE_RAW_MIME=true

# Only keep the content of mail sent within this many months; 0 keeps everything.
# Older mail is stored as headers alone (it still lists, threads and searches by
# subject/sender), and stored mail is stripped back to headers as the window
# slides past it. Nothing is deleted from the mail server. Same two homes as
# STORE_RAW_MIME: here for the containerised agent, content_window_months in
# agent/config.toml for a native one (and that file wins if it sets the key).
CONTENT_WINDOW_MONTHS=0


# Optional password required to use the web UI / REST API. Leave empty for an
# open localhost app; set it (plus TLS) when deploying to a remote server. The
# UI asks for it once, then a signed session cookie lasts SESSION_MAX_AGE_DAYS.
SERVER_PASSWORD=

# How long a browser login lasts before the password is asked again. Changing
# SERVER_PASSWORD or SECRET_KEY logs every browser out immediately.
SESSION_MAX_AGE_DAYS=30

# Default search time-window in years (0 = search everything). The UI can override.
DEFAULT_SEARCH_YEARS=0

# How many years back to scan addresses for compose autocomplete (0 = all time).
CONTACTS_SCAN_YEARS=1
