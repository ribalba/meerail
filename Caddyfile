# Caddy terminates TLS for the public deployment (docker-compose.tls.yml).
#
# Caddy obtains and renews a Let's Encrypt certificate on its own — the only
# requirements are that MEERAIL_DOMAIN resolves to this host and that ports 80
# and 443 reach it. Port 80 is not a redirect convenience: it is where the ACME
# HTTP challenge lands, so it has to stay open even though nothing is served on
# it (Caddy redirects it to https itself).
{
	# Where Let's Encrypt sends expiry warnings if renewal ever stops working.
	email {$ACME_EMAIL}
}

{$MEERAIL_DOMAIN} {
	# `server` is the compose service name; the base stack no longer publishes
	# port 8000 to the host, so this internal hop is the only way in.
	reverse_proxy server:8000 {
		# Streaming responses (attachment downloads, long searches) must not be
		# buffered or cut off mid-flight.
		flush_interval -1
	}

	encode zstd gzip
}
