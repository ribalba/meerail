{
  "name": "meerail-desktop",
  "productName": "meerail",
  "version": "0.1.0",
  "description": "Desktop wrapper for the meerail email client.",
  "main": "main.js",
  "author": "meerail",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "42.5.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.meerail.desktop",
    "productName": "meerail",
    "directories": { "buildResources": "build", "output": "dist" },
    "files": ["main.js", "package.json"],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "icon": "build/icon.png"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
